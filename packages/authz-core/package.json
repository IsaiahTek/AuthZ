{
  "name": "@vynelix/authz-core",
  "version": "0.1.0",
  "description": "Production-grade, framework-agnostic RBAC + PBAC authorization engine with sub-microsecond evaluation latency.",
  "author": {
    "name": "Engr., Isaiah Pius",
    "email": "isaiahtech1@gmail.com",
    "url": "https://github.com/IsaiahTek"
  },
  "license": "MIT",
  "homepage": "https://github.com/IsaiahTek/AuthZ#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/IsaiahTek/AuthZ.git",
    "directory": "packages/authz-core"
  },
  "bugs": {
    "url": "https://github.com/IsaiahTek/AuthZ/issues"
  },
  "keywords": [
    "authorization",
    "authz",
    "rbac",
    "pbac",
    "abac",
    "access-control",
    "permissions",
    "policy",
    "roles",
    "security",
    "typescript",
    "node"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.0.0",
    "typescript": "^5.0.0"
  }
}
