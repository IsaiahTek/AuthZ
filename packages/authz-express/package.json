{
  "name": "@vynelix/authz-express",
  "version": "0.1.0",
  "description": "Express.js middleware for the @vynelix/authz-core authorization SDK.",
  "author": {
    "name": "Engr., Isaiah Pius",
    "email": "isaiahtech1@gmail.com",
    "url": "https://github.com/IsaiahTek"
  },
  "license": "MIT",
  "homepage": "https://github.com/IsaiahTek/AuthZ/tree/main/packages/authz-express#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/IsaiahTek/AuthZ.git",
    "directory": "packages/authz-express"
  },
  "bugs": {
    "url": "https://github.com/IsaiahTek/AuthZ/issues"
  },
  "keywords": [
    "authorization",
    "authz",
    "rbac",
    "pbac",
    "express",
    "middleware",
    "access-control",
    "permissions",
    "security",
    "typescript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "vitest run"
  },
  "dependencies": {
    "@vynelix/authz-core": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "express": "^4.18.2",
    "tsup": "^8.0.0",
    "vitest": "^1.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  }
}
