{
  "name": "@vynelix/authz-nestjs",
  "version": "0.1.0",
  "description": "NestJS module and guard for the @vynelix/authz-core authorization SDK.",
  "author": {
    "name": "Engr., Isaiah Pius",
    "email": "isaiahtech1@gmail.com",
    "url": "https://github.com/IsaiahTek"
  },
  "license": "MIT",
  "homepage": "https://github.com/IsaiahTek/AuthZ/tree/main/packages/authz-nestjs#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/IsaiahTek/AuthZ.git",
    "directory": "packages/authz-nestjs"
  },
  "bugs": {
    "url": "https://github.com/IsaiahTek/AuthZ/issues"
  },
  "keywords": [
    "authorization",
    "authz",
    "rbac",
    "pbac",
    "nestjs",
    "guard",
    "decorator",
    "module",
    "access-control",
    "permissions",
    "security",
    "typescript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "vitest run"
  },
  "dependencies": {
    "@vynelix/authz-core": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "rxjs": "^7.8.1",
    "reflect-metadata": "^0.1.13",
    "@swc/core": "^1.7.26",
    "unplugin-swc": "^1.4.5",
    "tsup": "^8.0.0",
    "vitest": "^1.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0"
  }
}
